# =========================================
# App
# =========================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
LOG_LEVEL="info"
NODE_ENV="development"

# =========================================
# Supabase (Auth + DB + Storage 통합)
#   1) https://supabase.com 에서 프로젝트 생성
#   2) Settings → API에서 아래 키 복사
#   3) Auth → URL Configuration에 http://localhost:3000/auth/callback 추가
#   4) supabase/migrations/* SQL을 SQL Editor에 실행 (또는 Supabase CLI 사용)
# =========================================
NEXT_PUBLIC_SUPABASE_URL=""           # 예: https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=""      # public anon key
SUPABASE_SERVICE_ROLE_KEY=""          # ⚠️ 서버 전용 — 절대 클라이언트 노출 금지

SUPABASE_BUCKET_VIDEOS="videos"
SUPABASE_BUCKET_SUBTITLES="subtitles"

# =========================================
# Redis (BullMQ) — STT 잡 큐
# Self-host Whisper 워커와 동일 Redis 사용
# 로컬: 별도 설치 또는 Upstash 무료 티어
# =========================================
REDIS_URL="redis://localhost:6379"

# =========================================
# Email (Resend) — 잡 완료 알림 (Supabase Auth 외 추가 알림)
# =========================================
RESEND_API_KEY=""
EMAIL_FROM="make-cc <no-reply@localhost>"

# =========================================
# Discord (discord-integration) — 봇 DM 알림 + Account Linking
#   1. https://discord.com/developers/applications → New Application (make-cc-bot)
#   2. Bot 탭 → Reset Token → 아래 DISCORD_BOT_TOKEN 에 붙여넣기 (권한: Send Messages만)
#   3. OAuth2 → Redirects 에 {APP_URL}/auth/discord/callback 추가
#   4. Supabase Dashboard → Authentication → Providers → Discord 활성화 + Manual Linking ON
#   5. 서버 생성 후 초대 링크를 NEXT_PUBLIC_DISCORD_INVITE_URL 에 입력
# 미설정 시 Discord 기능 비활성 — 이메일 알림만 동작 (graceful degrade)
# =========================================
DISCORD_BOT_TOKEN=""                       # ⚠️ 서버/워커 전용 — 절대 클라이언트 노출 금지
DISCORD_OAUTH_REDIRECT_URL=""              # 예: http://localhost:3000/auth/discord/callback
DISCORD_GUILD_ID=""                        # (옵션) 서버 참여 여부 점검용 guild id
NEXT_PUBLIC_DISCORD_INVITE_URL=""          # 예: https://discord.gg/xxxxxxx

# =========================================
# Ads (Google AdSense) — 무료 티어 광고 (선택)
#   1. https://adsense.google.com 가입 → 사이트 추가(도메인 등록) → 승인 대기
#   2. 광고 → 광고 단위 기준 → 디스플레이 광고 생성 → client(ca-pub-…) / slot ID 복사
#   3. 아래에 입력 → AdSlot이 실제 광고 렌더
# 미설정 시 광고 슬롯은 플레이스홀더로 표시. AdSense는 승인된 도메인에서만 서빙(localhost 미서빙 가능)
# =========================================
NEXT_PUBLIC_ADSENSE_CLIENT=""              # 퍼블리셔 ID (예: ca-pub-1234567890123456)
NEXT_PUBLIC_ADSENSE_SLOT=""                # 기본 광고 유닛 slot ID (AdSlot 고정 위치)

# =========================================
# Whisper / Speaker Diarization (워커 전용)
# =========================================
WHISPER_MODEL="small"             # tiny|base|small|medium|large-v2|large-v3
WHISPER_DEVICE="auto"             # auto|cuda|cpu
WHISPER_DIARIZATION="true"        # true=화자 분리 켜기, false=STT만

# 화자 수 힌트 (pyannote에 전달, 정확도 향상)
WHISPER_MIN_SPEAKERS="1"
WHISPER_MAX_SPEAKERS="10"

# HuggingFace Token — pyannote.audio 다운로드용
#   1. https://huggingface.co/settings/tokens 에서 Read 권한 토큰 발급
#   2. https://huggingface.co/pyannote/segmentation-3.0 → "Agree" 동의
#   3. https://huggingface.co/pyannote/speaker-diarization-3.1 → "Agree" 동의
#   4. 아래에 토큰 붙여넣기
# 미설정 시 워커는 화자 분리 없이 일반 STT만 수행 (graceful degrade)
HUGGINGFACE_TOKEN=""

# =========================================
# 게스트/회원 캡 정책
# =========================================
GUEST_DURATION_LIMIT_SEC="300"          # 5분
GUEST_SIZE_LIMIT_BYTES="209715200"      # 200MB
MEMBER_DURATION_LIMIT_SEC="1800"        # 30분
MEMBER_SIZE_LIMIT_BYTES="1073741824"    # 1GB
GUEST_DAILY_GLOBAL_CAP_JOBS="500"       # 전체 게스트 일일 총 잡 수
GUEST_DAILY_GLOBAL_CAP_DURATION="36000" # 전체 게스트 일일 총 영상 길이(초)
