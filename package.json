{
  "name": "make-cc",
  "version": "0.7.0",
  "private": true,
  "description": "영상을 업로드하면 한국어 CC(폐쇄형 자막)를 자동 생성하는 웹 서비스",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:gen-types": "supabase gen types typescript --linked > src/lib/supabase/database.types.ts",
    "worker": "tsx --env-file=.env worker/index.ts",
    "worker:once": "tsx --env-file=.env worker/cli/process-one.ts",
    "worker:ingest": "tsx --env-file=.env worker/cli/ingest-and-run.ts",
    "worker:poll": "tsx --env-file=.env worker/cli/poll-loop.ts",
    "worker:render": "tsx --env-file=.env worker/cli/render-one.ts",
    "worker:models": "python worker/scripts/download_audio_tagging.py",
    "discord:setup": "node --env-file=.env scripts/discord-setup.mjs",
    "discord:relay": "node --env-file=.env scripts/discord-automod-relay.mjs",
    "usage": "node --env-file=.env scripts/usage-stats.mjs",
    "funnel": "node --env-file=.env scripts/analytics-funnel.mjs",
    "jira:sync": "node --env-file=.env scripts/jira-sync.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@supabase/ssr": "^0.5.1",
    "@supabase/supabase-js": "^2.45.4",
    "@tailwindcss/postcss": "^4.3.1",
    "@tanstack/react-query": "^5.59.0",
    "bullmq": "^5.13.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "ioredis": "^5.4.1",
    "lucide-react": "^0.447.0",
    "motion": "^12.40.0",
    "next": "^15.0.0",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "resend": "^4.0.0",
    "tailwind-merge": "^2.5.2",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^20.16.0",
    "@types/react": "^18.3.10",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "@vitejs/plugin-react": "^4.3.2",
    "eslint": "^9.11.1",
    "eslint-config-next": "^15.0.0",
    "eslint-config-prettier": "^9.1.0",
    "playwright": "^1.61.1",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "tsx": "^4.22.4",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
